# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=expense_auditor

# OCR provider: tesseract | google_vision (extensible)
OCR_PROVIDER=tesseract

# LLM (optional - set LLM_ENABLED=false to skip LLM checks)
LLM_ENABLED=false
OPENAI_API_KEY=sk-...

# Upload limits
MAX_UPLOAD_MB=20

# Policy defaults
POLICY_AMOUNT_THRESHOLD=1000.0
POLICY_ALLOWED_CURRENCIES=USD,EUR,GBP,INR
POLICY_ALLOW_WEEKEND_EXPENSES=false

# App
APP_ENV=development
LOG_LEVEL=INFO
